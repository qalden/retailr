# PostgreSQL Configuration
POSTGRES_USER=retailr_user
POSTGRES_PASSWORD=retailr_password
POSTGRES_DB=retailr_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Spring Boot Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/retailr_db
SPRING_DATASOURCE_USERNAME=retailr_user
SPRING_DATASOURCE_PASSWORD=retailr_password

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Service Ports
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
CATALOG_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
FRONTEND_PORT=3000

# Service URLs
AUTH_SERVICE_URL=http://auth-service:8081
CATALOG_SERVICE_URL=http://catalog-service:8082
ORDER_SERVICE_URL=http://order-service:8083

# Frontend API Configuration
VITE_API_BASE_URL=http://localhost:8080

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_RETAILR=DEBUG
